# AI Course Generator environment
# CHANGE THIS TO YOUR MODEL AI
# CORS - Frontend origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── NVIDIA NIM (LLM) ──────────────────────────────────────────────────────────
NVIDIA_API_KEY=YOUR_API_KEY
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=qwen/qwen3-next-80b-a3b-instruct
# Set LLM_FALLBACK_MODELS to 'none' or empty to stick to LLM_MODEL (no fallback)
LLM_FALLBACK_MODELS=none
# Maximum retry attempts on 429 (Too Many Requests). High value allows the client to sleep longer and retry.
LLM_MAX_RETRIES=8

# Embedding Model
EMBEDDING_MODEL=baai/bge-m3

# ─── ComfyUI (Local Image Generation) ──────────────────────────────────────────
COMFYUI_ENABLED=true
COMFYUI_SERVER=127.0.0.1:8188
SLIDES_IMAGES_DIR=slides_images

