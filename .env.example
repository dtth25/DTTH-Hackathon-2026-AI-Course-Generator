# Backend-only secret. Never put this in frontend code or GitHub.
# Gemini API keys usually look like: AIzaSy...
GOOGLE_API_KEY=your_gemini_api_key_here

# Gemini model
GEMINI_MODEL=gemini-2.5-flash

# Keep false for real AI. Set true if you only want to demo UI/course flow without Gemini.
DEMO_MODE=false

# If Gemini key/quota/network fails, backend will return a clearly marked demo course instead of crashing.
AUTO_DEMO_ON_AI_ERROR=true

# Upload and context limits
MAX_UPLOAD_MB=50
MAX_CONTEXT_CHARS=45000
MIN_TEXT_CHARS=200

# OCR is optional. Enable only if you upload scanned PDFs and have Tesseract installed.
ENABLE_OCR=false
TESSERACT_CMD=
OCR_LANG=vie+eng
